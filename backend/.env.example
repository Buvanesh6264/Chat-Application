NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/chat-app?retryWrites=true&w=majority

JWT_SECRET=replace_with_a_long_random_string
JWT_REFRESH_SECRET=replace_with_a_different_long_random_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Supabase Storage — S3-compatible API. Backend-only credentials, never ship these to the frontend.
STORAGE_ENDPOINT=https://<project-ref>.storage.supabase.co/storage/v1/s3
STORAGE_ACCESS_KEY=replace_with_storage_access_key
STORAGE_SECRET_KEY=replace_with_storage_secret_key
STORAGE_BUCKET=chat-media
STORAGE_REGION=us-east-1

GROQ_API_KEY=replace_with_groq_api_key
GROQ_STT_MODEL=whisper-large-v3
GROQ_TRANSLATE_MODEL=llama-3.3-70b-versatile

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_ATTEMPTS=5
